<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>StartLocal - Candidatos da Vaga</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="d-flex flex-column min-vh-100 bg-light">

    <%- include('partials/navbar') %>

    <main class="flex-grow-1 py-5">
        <div class="container container-lg-vagas">
            
            <!-- BREADCRUMB -->
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/dashboard-empresa">Painel da Empresa</a></li>
                    <li class="breadcrumb-item active" aria-current="page"><%= vaga.titulo %></li>
                </ol>
            </nav>

            <div class="card border-0 shadow-sm mt-3 p-4 mb-4">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h3 class="fw-bold text-primary mb-1"><%= vaga.titulo %></h3>
                        <p class="text-muted mb-0"><i class="bi bi-people me-2"></i>Candidatos Inscritos: <strong><%= candidatos.length %></strong></p>
                    </div>
                </div>
            </div>

            <h5 class="fw-bold mb-3"><i class="bi bi-person-lines-fill me-2 text-primary"></i>Lista de Candidatos</h5>

            <% if (candidatos && candidatos.length > 0) { %>
                <div class="row g-3">
                    <% candidatos.forEach(function(cand) { %>
                        <div class="col-12">
                            <article class="card border-0 shadow-sm vaga-card">
                                <div class="card-body p-4">
                                    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-start gap-3 mb-3">
                                        <div class="d-flex align-items-start gap-3">
                                            <i class="bi bi-person-circle text-primary avatar-md" aria-hidden="true"></i>
                                            <div>
                                                <h3 class="h5 fw-bold mb-1"><%= cand.nome %></h3>
                                                <p class="text-muted small mb-1">
                                                    <i class="bi bi-envelope me-1"></i>
                                                    <a href="mailto:<%= cand.email %>" class="text-decoration-none"><%= cand.email %></a>
                                                </p>
                                                <p class="text-muted small mb-0">
                                                    <i class="bi bi-mortarboard me-1"></i><%= cand.curso || 'Curso não informado' %>
                                                </p>
                                            </div>
                                        </div>
                                        <div class="text-md-end">
                                            <p class="text-muted small mb-1">Inscrito em</p>
                                            <span class="badge bg-success bg-opacity-10 text-success px-3 py-2 border border-success-subtle rounded-pill">
                                                <%= cand.dataInscricao ? new Date(cand.dataInscricao).toLocaleDateString('pt-BR') : 'Data não disponível' %>
                                            </span>
                                        </div>
                                    </div>

                                    <% if (cand.resumo) { %>
                                        <p class="small text-muted mb-3 text-pre-line"><strong>Resumo:</strong> <%= cand.resumo %></p>
                                    <% } %>

                                    <% if (cand.habilidades) { %>
                                        <div class="mb-2">
                                            <span class="small fw-semibold text-secondary d-block mb-1">Habilidades</span>
                                            <div class="d-flex flex-wrap gap-1">
                                                <% cand.habilidades.split(',').forEach(function(skill) { %>
                                                    <% if (skill.trim()) { %>
                                                        <span class="badge bg-primary bg-opacity-10 text-primary border"><%= skill.trim() %></span>
                                                    <% } %>
                                                <% }) %>
                                            </div>
                                        </div>
                                    <% } %>

                                    <% if (cand.conhecimentos) { %>
                                        <div class="mb-2">
                                            <span class="small fw-semibold text-secondary d-block mb-1">Conhecimentos</span>
                                            <div class="d-flex flex-wrap gap-1">
                                                <% cand.conhecimentos.split(',').forEach(function(item) { %>
                                                    <% if (item.trim()) { %>
                                                        <span class="badge bg-light text-dark border"><%= item.trim() %></span>
                                                    <% } %>
                                                <% }) %>
                                            </div>
                                        </div>
                                    <% } %>

                                    <% if (cand.experiencia) { %>
                                        <div class="mt-3 pt-3 border-top">
                                            <span class="small fw-semibold text-secondary d-block mb-1">Experiência e projetos</span>
                                            <p class="small text-muted mb-0 text-pre-line"><%= cand.experiencia %></p>
                                        </div>
                                    <% } %>

                                    <% if (!cand.resumo && !cand.habilidades && !cand.conhecimentos && !cand.experiencia) { %>
                                        <p class="small text-muted mb-0 fst-italic">Candidato ainda não preencheu o currículo no site.</p>
                                    <% } %>
                                </div>
                            </article>
                        </div>
                    <% }) %>
                </div>
            <% } else { %>
                <div class="text-center py-5 bg-white rounded shadow-sm border border-dashed border-secondary-subtle">
                    <i class="bi bi-inbox display-4 text-muted mb-3 opacity-50"></i>
                    <h5 class="fw-bold text-dark">Nenhum candidato ainda.</h5>
                    <p class="text-muted small">Sua vaga está visível, aguarde os estudantes se inscreverem!</p>
                </div>
            <% } %>

        </div>
    </main>

    <%- include('partials/footer') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
