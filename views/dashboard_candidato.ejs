<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>StartLocal - Meu Perfil</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="d-flex flex-column min-vh-100 bg-light">

    <!-- NAVBAR COM SESSÃO INTELIGENTE -->
    <%- include('partials/navbar') %>

    <main class="flex-grow-1 py-5">
        <div class="container">
            <!-- HEADER DO DASHBOARD -->
            <div class="row g-4">
                
                <!-- COLUNA ESQUERDA: PERFIL DO USUÁRIO -->
                <div class="col-lg-4">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body text-center p-4">
                            <!-- Avatar -->
                            <div class="mb-3">
                                <i class="bi bi-person-circle text-primary" style="font-size: 5.5rem;"></i>
                            </div>
                            
                            <!-- Informações Principais -->
                            <h4 class="fw-bold mb-1"><%= candidato.nome %></h4>
                            <p class="text-muted mb-4"><i class="bi bi-envelope me-2"></i><%= candidato.email %></p>
                            
                            <hr class="text-muted">
                            
                            <!-- Formação -->
                            <div class="text-start mb-4 mt-4">
                                <h6 class="fw-bold text-secondary text-uppercase" style="font-size: 0.8rem; letter-spacing: 1px;">
                                    Formação Acadêmica
                                </h6>
                                <p class="mb-0 fs-6">
                                    <i class="bi bi-mortarboard-fill text-primary me-2"></i> 
                                    <%= candidato.curso || 'Curso não cadastrado' %>
                                </p>
                            </div>
                            
                            <!-- Skills -->
                            <div class="text-start">
                                <h6 class="fw-bold text-secondary text-uppercase" style="font-size: 0.8rem; letter-spacing: 1px;">
                                    Minhas Habilidades (Skills)
                                </h6>
                                <div class="d-flex flex-wrap gap-2 mt-2">
                                    <% if (candidato.habilidades) { %>
                                        <% candidato.habilidades.split(',').forEach(function(skill) { %>
                                            <span class="badge bg-primary bg-opacity-10 text-primary border border-primary-subtle px-3 py-2 rounded-pill">
                                                <%= skill.trim() %>
                                            </span>
                                        <% }) %>
                                    <% } else { %>
                                        <span class="text-muted small">Nenhuma habilidade cadastrada no momento.</span>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- COLUNA DIREITA: CONTEÚDO PRINCIPAL -->
                <div class="col-lg-8">
                    
                    <!-- PAINEL DE CANDIDATURAS -->
                    <div class="card border-0 shadow-sm mb-4">
                        <div class="card-body p-4">
                            <h5 class="fw-bold mb-3 border-bottom pb-2">
                                <i class="bi bi-send-check-fill text-success me-2"></i>Vagas que me Candidatei
                            </h5>
                            
                            <!-- Loop de vagas candidatadas pelo Banco -->
                            <% if (typeof vagasCandidatadas !== 'undefined' && vagasCandidatadas.length > 0) { %>
                                <div class="list-group list-group-flush border rounded">
                                    <% vagasCandidatadas.forEach(function(vaga) { %>
                                        <div class="list-group-item d-flex justify-content-between align-items-center py-3">
                                            <div>
                                                <h6 class="fw-bold mb-1"><%= vaga.titulo %></h6>
                                                <small class="text-muted"><i class="bi bi-building me-1"></i><%= vaga.empresa %></small>
                                            </div>
                                            <div>
                                                <span class="badge bg-success py-2"><i class="bi bi-check2-circle me-1"></i>Inscrito</span>
                                                <a href="/vaga/<%= vaga._id %>" class="btn btn-sm btn-outline-secondary ms-2" title="Ver Vaga">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                            </div>
                                        </div>
                                    <% }) %>
                                </div>
                            <% } else { %>
                                <!-- Placeholder vazio -->
                                <div class="text-center py-5 bg-light rounded text-muted border border-dashed border-secondary-subtle">
                                    <i class="bi bi-folder2-open display-4 mb-2 opacity-50"></i>
                                    <h5 class="fw-bold text-dark mt-2">Nenhuma candidatura ativa</h5>
                                    <p class="small mb-4 px-md-5">As vagas que você demonstrar interesse e enviar seu currículo aparecerão listadas aqui para você acompanhar o status do processo seletivo.</p>
                                    <a href="/vagas" class="btn btn-outline-primary fw-bold px-4">
                                        Buscar Novas Oportunidades
                                    </a>
                                </div>
                            <% } %>
                        </div>
                    </div>

                    <!-- VAGAS RECOMENDADAS PELO SISTEMA -->
                    <h5 class="fw-bold mb-3 mt-5">
                        <i class="bi bi-stars text-warning me-2"></i>Oportunidades Recomendadas
                    </h5>
                    
                    <div class="row g-3">
                        <% if (vagasRecentes && vagasRecentes.length > 0) { %>
                            <% vagasRecentes.slice(0, 4).forEach(function(vaga) { %>
                                <div class="col-md-6">
                                    <div class="card h-100 border-0 shadow-sm vaga-card">
                                        <div class="card-body d-flex flex-column">
                                            <div class="d-flex justify-content-between align-items-start mb-2">
                                                <h6 class="card-title fw-bold mb-0 text-truncate pe-2"><%= vaga.titulo %></h6>
                                                <% if (vaga.nivel === 'basico') { %>
                                                    <span class="badge bg-success">BSC</span>
                                                <% } else if (vaga.nivel === 'intermediario') { %>
                                                    <span class="badge bg-warning text-dark">INT</span>
                                                <% } else { %>
                                                    <span class="badge bg-danger">AVN</span>
                                                <% } %>
                                            </div>
                                            <p class="text-muted small mb-1">
                                                <i class="bi bi-building me-1"></i><%= vaga.empresa %>
                                            </p>
                                            <p class="text-success small fw-bold mb-3"><%= vaga.bolsa %> — <%= vaga.cargaHoraria %></p>
                                            
                                            <div class="mt-auto">
                                                <a href="/vaga/<%= vaga._id %>" class="btn btn-outline-primary btn-sm w-100 fw-bold">Ver detalhes da vaga</a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <div class="col-12 text-center text-muted py-4">
                                <p>Não há vagas recomendadas no momento.</p>
                            </div>
                        <% } %>
                    </div>
                    
                </div>
            </div>
        </div>
    </main>

    <%- include('partials/footer') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
