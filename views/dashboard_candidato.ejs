<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>StartLocal - Meu Dashboard</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="d-flex flex-column min-vh-100">

    <!-- NAVBAR COM USUÁRIO LOGADO -->
    <nav class="navbar navbar-expand-lg bg-primary">
        <div class="container-fluid px-4">
            <a class="navbar-brand text-white fw-bold" href="/"><i class="bi bi-briefcase-fill me-2"></i>StartLocal</a>
            <div class="ms-auto d-flex align-items-center gap-3">
                <span class="text-white">
                    <i class="bi bi-person-circle me-1"></i>
                    Olá, <strong><%= candidato.nome.split(' ')[0] %></strong>
                </span>
                <a href="/vagas" class="btn btn-light btn-sm">
                    <i class="bi bi-search me-1"></i>Ver Vagas
                </a>
                <a href="/logout" class="btn btn-outline-light btn-sm">
                    <i class="bi bi-box-arrow-right me-1"></i>Sair
                </a>
            </div>
        </div>
    </nav>

    <main class="flex-grow-1 py-5">
        <div class="container">

            <!-- BOAS VINDAS -->
            <div class="row mb-4">
                <div class="col">
                    <div class="bg-light rounded p-4 d-flex align-items-center gap-3">
                        <i class="bi bi-person-circle display-4 text-primary"></i>
                        <div>
                            <h4 class="fw-bold mb-1">Bem-vindo, <%= candidato.nome %>!</h4>
                            <p class="text-muted mb-0"><%= candidato.email %></p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- CARDS RÁPIDOS -->
            <div class="row g-3 mb-5">
                <div class="col-md-4">
                    <a href="/vagas?nivel=basico" class="text-decoration-none">
                        <div class="card border-0 shadow-sm text-center p-3 h-100">
                            <div class="card-body">
                                <span class="badge bg-success fs-6 px-3 py-2">Básico</span>
                                <p class="mt-2 mb-0 text-muted small">Para quem está começando</p>
                            </div>
                        </div>
                    </a>
                </div>
                <div class="col-md-4">
                    <a href="/vagas?nivel=intermediario" class="text-decoration-none">
                        <div class="card border-0 shadow-sm text-center p-3 h-100">
                            <div class="card-body">
                                <span class="badge bg-warning text-dark fs-6 px-3 py-2">Intermediário</span>
                                <p class="mt-2 mb-0 text-muted small">Com alguma experiência</p>
                            </div>
                        </div>
                    </a>
                </div>
                <div class="col-md-4">
                    <a href="/vagas?nivel=avancado" class="text-decoration-none">
                        <div class="card border-0 shadow-sm text-center p-3 h-100">
                            <div class="card-body">
                                <span class="badge bg-danger fs-6 px-3 py-2">Avançado</span>
                                <p class="mt-2 mb-0 text-muted small">Alta senioridade técnica</p>
                            </div>
                        </div>
                    </a>
                </div>
            </div>

            <!-- VAGAS RECENTES -->
            <h5 class="fw-bold mb-3"><i class="bi bi-clock-history me-2 text-primary"></i>Vagas Recentes</h5>
            <div class="row g-3">
                <% vagasRecentes.forEach(function(vaga) { %>
                    <div class="col-md-6">
                        <div class="card h-100 border-0 shadow-sm">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <h6 class="card-title fw-bold mb-0"><%= vaga.titulo %></h6>
                                    <% if (vaga.nivel === 'basico') { %>
                                        <span class="badge bg-success ms-2">Básico</span>
                                    <% } else if (vaga.nivel === 'intermediario') { %>
                                        <span class="badge bg-warning text-dark ms-2">Intermediário</span>
                                    <% } else { %>
                                        <span class="badge bg-danger ms-2">Avançado</span>
                                    <% } %>
                                </div>
                                <p class="text-muted small mb-1">
                                    <i class="bi bi-building me-1"></i><%= vaga.empresa %> &nbsp;|&nbsp;
                                    <i class="bi bi-geo-alt me-1"></i><%= vaga.cidade %>
                                </p>
                                <p class="text-success small fw-bold mb-2"><%= vaga.bolsa %> — <%= vaga.cargaHoraria %></p>
                                <a href="/vagas" class="btn btn-outline-primary btn-sm">Ver detalhes</a>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>

            <div class="text-center mt-4">
                <a href="/vagas" class="btn btn-primary">
                    <i class="bi bi-search me-2"></i>Ver todas as vagas
                </a>
            </div>

        </div>
    </main>

    <%- include('partials/footer') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
