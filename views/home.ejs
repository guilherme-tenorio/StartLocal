<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>StartLocal - Sua Primeira Oportunidade em TI</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="d-flex flex-column min-vh-100">

    <%- include('partials/navbar') %>

    <main class="flex-grow-1">
        <!-- HERO -->
        <section class="section-hero">
            <div class="container">
                <div class="row align-items-center min-vh-100 py-5">
                    <div class="col-md-6 col-sm-12 d-flex flex-column justify-content-center">
                        <span class="badge bg-primary mb-3 fs-6 w-auto d-inline-block px-3 py-2">
                            <i class="bi bi-rocket-takeoff me-1"></i> SUA PRIMEIRA OPORTUNIDADE EM TI
                        </span>
                        <h1 class="display-5 fw-bold mb-3">Conectando talentos ao mercado de tecnologia</h1>
                        <p class="lead text-muted mb-4">
                            Encontre o estágio ideal de acordo com o seu nível de conhecimento.
                            Vagas organizadas em <strong>Básico</strong>, <strong>Intermediário</strong> e <strong>Avançado</strong>.
                        </p>
                        <div class="d-flex gap-3 flex-wrap">
                            <a href="/login-candidato" class="btn btn-primary btn-lg">
                                <i class="bi bi-person-fill me-2"></i>Sou Candidato
                            </a>
                            <a href="/login-empresa" class="btn btn-warning btn-lg">
                                <i class="bi bi-building me-2"></i>Sou Empresa
                            </a>
                            <a href="/vagas" class="btn btn-outline-secondary btn-lg">
                                <i class="bi bi-search me-2"></i>Ver Vagas
                            </a>
                        </div>
                    </div>
                    <div class="col-md-6 col-sm-12 d-flex justify-content-center mt-5 mt-md-0">
                        <img src="/css/img/Logo_StartLocal.png" alt="Logotipo gigante do portal de estágios StartLocal, focado em estudantes de tecnologia (mapa com chapéu de formatura)." class="img-fluid drop-shadow" style="max-width: 490px;">
                    </div>
                </div>
            </div>
        </section>

        <!-- DIFERENCIAIS -->
        <section class="py-5 bg-light">
            <div class="container">
                <h2 class="text-center fw-bold mb-5">Por que usar o StartLocal?</h2>
                <div class="row g-4">
                    <div class="col-md-4">
                        <div class="card h-100 border-0 shadow-sm text-center p-3">
                            <div class="card-body">
                                <div class="display-4 text-success mb-3"><i class="bi bi-bar-chart-steps"></i></div>
                                <h5 class="card-title fw-bold">Vagas por Nível</h5>
                                <p class="card-text text-muted">Vagas separadas em Básico, Intermediário e Avançado. Encontre a que combina com você.</p>
                                <div class="d-flex justify-content-center gap-2 mt-3">
                                    <a href="/vagas?nivel=basico" class="badge bg-success text-decoration-none">Básico</a>
                                    <a href="/vagas?nivel=intermediario" class="badge bg-warning text-dark text-decoration-none">Intermediário</a>
                                    <a href="/vagas?nivel=avancado" class="badge bg-danger text-decoration-none">Avançado</a>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card h-100 border-0 shadow-sm text-center p-3">
                            <div class="card-body">
                                <div class="display-4 text-primary mb-3"><i class="bi bi-person-check-fill"></i></div>
                                <h5 class="card-title fw-bold">Para Candidatos</h5>
                                <p class="card-text text-muted">Crie seu perfil, encontre vagas compatíveis com seu nível e candidate-se com facilidade.</p>
                                <a href="/cadastro-candidato" class="btn btn-outline-primary btn-sm mt-2">Criar conta grátis</a>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card h-100 border-0 shadow-sm text-center p-3">
                            <div class="card-body">
                                <div class="display-4 text-warning mb-3"><i class="bi bi-building-fill-check"></i></div>
                                <h5 class="card-title fw-bold">Para Empresas</h5>
                                <p class="card-text text-muted">Publique vagas e alcance estudantes de TI que já têm o nível técnico que você procura.</p>
                                <a href="/cadastro-empresa" class="btn btn-outline-warning btn-sm mt-2">Cadastrar empresa</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- CTA VAGAS -->
        <section class="py-5">
            <div class="container text-center">
                <h2 class="fw-bold mb-3">Vagas disponíveis agora</h2>
                <p class="text-muted mb-4">Mais de 9 vagas ativas em empresas de Alagoas e remotas.</p>
                <a href="/vagas" class="btn btn-primary btn-lg">
                    <i class="bi bi-search me-2"></i>Explorar Vagas
                </a>
            </div>
        </section>
    </main>

    <%- include('partials/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
