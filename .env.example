# ============================================================
# STARTLOCAL — Variáveis de Ambiente
# ============================================================
# Copie este arquivo para .env e preencha com suas credenciais:
#   cp .env.example .env
#
# ⚠️  NUNCA suba o arquivo .env para o repositório.
#     Ele já está listado no .gitignore.
# ============================================================

# String de conexão do MongoDB Atlas
# Como obter: Atlas → seu cluster → Connect → Drivers → copie a URI
# Substitua <usuario>, <senha> e <cluster> pelos seus dados reais.
MONGODB_URI=mongodb+srv://<usuario>:<senha>@<cluster>.mongodb.net/startlocal?retryWrites=true&w=majority&appName=Cluster0

# Nome do banco de dados (pode manter como está)
MONGODB_DB=startlocal
