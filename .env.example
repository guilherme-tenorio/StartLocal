# Copie para .env — NÃO use cluster0.xxxxx.mongodb.net em mongodb:// (dá ENOTFOUND no Windows).
# No Atlas: Connect → Drivers → copie a string ou monte com os hosts shard-00-00, -01, -02:
# MONGODB_URI=mongodb://usuario:senha@host-shard-00-00.xxxxx.mongodb.net:27017,host-shard-00-01.xxxxx.mongodb.net:27017,host-shard-00-02.xxxxx.mongodb.net:27017/startlocal?ssl=true&authSource=admin&replicaSet=SEU-REPLICA-SET&retryWrites=true&w=majority
MONGODB_DB=startlocal
